# ─────────────────────────────────────────────────────────────────
# WhatsApp Bot Configuration – IAMLEGEND by STANY TZ
# ─────────────────────────────────────────────────────────────────
# Rename this file to .env and fill in your details below

# ─────────────────────────────────────────────────────────────────
# 1️⃣ REQUIRED – Your WhatsApp session
# ─────────────────────────────────────────────────────────────────

# OPTION A: Use existing session ID (from pairing website)
# Format: Stanytz378/IAMLEGEND_abc123
SESSION_ID=Stanytz378/iamlegendv2_KU7QQNQS

# OPTION B: Generate new session via pairing code (first time only)
# Format: 255787069580 (no +, no spaces)
PAIRING_NUMBER=255618558502

# ─────────────────────────────────────────────────────────────────
# 2️⃣ REQUIRED – Owner information
# ─────────────────────────────────────────────────────────────────

# Your WhatsApp number (full international format, no +, no spaces)
OWNER_NUMBER=255618558502

# Your name (will appear in bot menus)
BOT_OWNER=STANYTZ

# ─────────────────────────────────────────────────────────────────
# 3️⃣ OPTIONAL – Bot behavior
# ─────────────────────────────────────────────────────────────────

# Command prefixes (comma separated, no spaces)
# Example: .,!,/  means commands can be .menu, !menu, or /menu
PREFIXES=.,!,/

# Bot display name
BOT_NAME=ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ

# Sticker pack info
PACKNAME=ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ
AUTHOR=STANY TZ

# Bot mode: public, private, groups, inbox, self
COMMAND_MODE=public

# Your timezone (for logs)
TIMEZONE=Africa/Nairobi

# ─────────────────────────────────────────────────────────────────
# 4️⃣ OPTIONAL – Performance
# ─────────────────────────────────────────────────────────────────

# Maximum messages stored per chat (lower = less RAM)
MAX_STORE_MESSAGES=20

# ─────────────────────────────────────────────────────────────────
# 5️⃣ OPTIONAL – Database (leave empty to use JSON files)
# ─────────────────────────────────────────────────────────────────

MONGO_URL=
POSTGRES_URL=
MYSQL_URL=
DB_URL=

# ─────────────────────────────────────────────────────────────────
# 6️⃣ OPTIONAL – External services
# ─────────────────────────────────────────────────────────────────

REMOVEBG_KEY=

# ─────────────────────────────────────────────────────────────────
# 7️⃣ OPTIONAL – Your social links (appear in bot menu)
# ─────────────────────────────────────────────────────────────────

CHANNEL_LINK=https://whatsapp.com/channel/0029Vb7fzu4EwEjmsD4Tzs1p
YT_CHANNEL=STANY TZ
NEWSLETTER_JID=120363404317544295@newsletter

# ─────────────────────────────────────────────────────────────────
# 8️⃣ Server port (Render will override this)
# ─────────────────────────────────────────────────────────────────

PORT=5000

# ─────────────────────────────────────────────────────────────────
# ✅ Fill in your values above and save as .env
# ─────────────────────────────────────────────────────────────────